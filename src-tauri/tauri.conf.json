{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VOCA",
  "version": "0.1.0",
  "identifier": "app.voca",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "VOCA",
        "width": 1080,
        "height": 720,
        "minWidth": 800,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "visible": false,
        "decorations": true,
        "center": true,
        "skipTaskbar": false
      },
      {
        "label": "status-bar",
        "title": "",
        "width": 380,
        "height": 72,
        "resizable": false,
        "fullscreen": false,
        "visible": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
